{
  "name": "concert-antibot",
  "version": "0.1.0",
  "private": true,
  "description": "ระบบจองบัตรคอนเสิร์ตที่มี anti-bot 2 ชั้น (scoring + behavior) + fairness queue (โปรเจ็คจบ ป.ตรี)",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "sweep": "tsx scripts/sweep-orders.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:race": "tsx scripts/test-n1-race.ts",
    "test:e2e": "playwright test",
    "test:load": "k6 run tests/load/queue.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.7.4",
    "@fingerprintjs/fingerprintjs": "4.5.1",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "6.1.0",
    "argon2": "0.41.1",
    "ioredis": "5.4.2",
    "lucide-react": "0.468.0",
    "next": "15.1.0",
    "next-auth": "5.0.0-beta.25",
    "promptpay-qr": "0.5.0",
    "qrcode": "1.5.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@tailwindcss/postcss": "4.0.14",
    "@types/node": "22.10.0",
    "@types/qrcode": "1.5.5",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "autoprefixer": "10.4.20",
    "docx": "^9.7.1",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.0",
    "playwright-core": "^1.60.0",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "prisma": "6.1.0",
    "tailwindcss": "4.0.14",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=9.15.0"
  }
}

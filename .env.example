# ===========================================
# Environment Variables (template)
# คัดลอกไฟล์นี้ไปเป็น .env แล้วเติมค่าจริง
# ห้าม commit .env เด็ดขาด (อยู่ใน .gitignore แล้ว)
# ===========================================

# ---------- Database (Postgres 16) ----------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://concert:dev_only_change_me@localhost:5432/concert_antibot?schema=public"
# DIRECT_URL = connection ตรง ไม่ผ่าน pooler — Prisma ใช้ตอน migrate deploy เท่านั้น
#   local docker: ตั้งเท่ากับ DATABASE_URL ได้เลย (ไม่มี pooler)
#   Vercel+Neon: DATABASE_URL ใช้ host ที่มี "-pooler", DIRECT_URL ใช้ host ที่ไม่มี "-pooler"
DIRECT_URL="postgresql://concert:dev_only_change_me@localhost:5432/concert_antibot?schema=public"
POSTGRES_USER=concert
POSTGRES_PASSWORD=dev_only_change_me
POSTGRES_DB=concert_antibot

# ---------- Redis ----------
REDIS_URL="redis://localhost:6379"

# ---------- MinIO (S3-compatible) ----------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me
MINIO_BUCKET=concert-assets

# ---------- NextAuth v5 ----------
# สร้าง secret ด้วย: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32BYTES_BASE64"
NEXTAUTH_URL="http://localhost:3000"

# ---------- Google OAuth ----------
# ขอจาก: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- Cloudflare Turnstile (CAPTCHA - ฟรี unlimited) ----------
# ขอจาก: https://dash.cloudflare.com → Turnstile
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ---------- FingerprintJS Open Source ----------
# v4 OSS ไม่ต้อง API key ใช้ฟรีได้เลย client-side

# ---------- Resend (Email - 3000/เดือนฟรี) ----------
# ขอจาก: https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="noreply@localhost"

# ---------- PromptPay (Payment) ----------
# เบอร์มือถือ หรือเลขประจำตัวประชาชน 13 หลัก
PROMPTPAY_ID=""

# ---------- EasySlip (Slip Verification - 500/เดือนฟรี) ----------
# ขอจาก: https://easyslip.com
EASYSLIP_API_KEY=""
# ชื่อบัญชีผู้รับเงินที่คาดหวัง (Codex #1) — ใส่หลายชื่อคั่น comma (ไทย/อังกฤษ)
# ตั้งแล้วสลิปต้องมีชื่อผู้รับตรงด้วย ปิดช่อง "บัญชี attacker ที่เลขท้ายพ้องกับร้าน"
# เว้นว่าง = เช็คเฉพาะเลขบัญชี (แนะนำให้ตั้งบน production)
PAYMENTS_RECEIVER_NAME=""

# ---------- Named Ticket (docs/19) ----------
# อายุบัญชีขั้นต่ำ (วัน) ของผู้ถือบัตรที่ไม่ใช่ผู้ซื้อ — กัน scalper ให้ลูกค้าสมัครบัญชีใหม่มารับบัตร
# 0 = ปิดเช็ค (ตั้ง 0 ตอน dev/demo ที่บัญชีเพิ่งสมัคร)
HOLDER_MIN_ACCOUNT_AGE_DAYS=30
# คืนบัตรได้ถึงกี่ชั่วโมงก่อนเริ่มงาน (ที่นั่งกลับเข้า pool ขายรอบใหม่)
RETURN_CUTOFF_HOURS=24

# ---------- Gemini AI (Google AI Studio - free tier) ----------
# ขอจาก: https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ---------- Queue Fairness — HMAC secret ----------
# ใช้คำนวณ deterministic randomScore กัน leave/rejoin re-roll
# สร้างด้วย: openssl rand -base64 32
QUEUE_SCORE_SECRET=""

# ---------- App Settings ----------
NODE_ENV=development
APP_NAME="Concert Anti-Bot"
APP_TIMEZONE="Asia/Bangkok"
APP_CURRENCY="THB"

# ---------- Queue/Anti-bot Settings ----------
# จำนวนคนที่ปล่อยจาก waiting room ต่อ batch
QUEUE_BATCH_SIZE=100
# ความจุ "ห้องเลือกที่นั่ง" (capacity-aware admission) — คนอยู่ในหน้าเลือกที่นั่งพร้อมกันได้สูงสุด
#   ปล่อยต่อรอบ = min(batch, cap − คนข้างใน, ที่นั่งเหลือ) + คืนความจุเมื่อคนจ่ายเสร็จ/หมดเวลา
#   ปรับสดต่อคอนเสิร์ตได้จากแผงแอดมิน /admin/queue (override ค่านี้). ควรตั้ง >= QUEUE_BATCH_SIZE
QUEUE_ADMIT_CAP=200
# Random window (ms) สำหรับ randomized batch release
QUEUE_BATCH_WINDOW_MS=1000
# Seat hold TTL (วินาที) — default 5 นาที
SEAT_HOLD_TTL_SECONDS=300
# Bot score threshold — ค่าคงที่ในโค้ด (lib/antibot.ts: CHALLENGE=40 / BLOCK=70, สเกล 0-100)
#   ไม่ได้อ่านจาก env — ตั้งตรงนี้ไม่มีผล (เดิมมี BOT_SCORE_THRESHOLD=0.5 ที่หลอกว่าปรับได้ จึงลบออก)

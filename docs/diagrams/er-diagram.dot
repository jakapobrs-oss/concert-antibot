  // ========== RELATIONSHIPS (crow's-foot: tee=one, crow=many, teeodot=zero-or-one) ==========
  USER -> ACCOUNT            [dir=both, arrowtail=tee, arrowhead=crow];
  USER -> SESSION            [dir=both, arrowtail=tee, arrowhead=crow];
  USER -> ORDER              [dir=both, arrowtail=tee, arrowhead=crow];
  USER -> TICKET             [dir=both, arrowtail=tee, arrowhead=crow];
  USER -> QUEUE_TOKEN        [dir=both, arrowtail=teeodot, arrowhead=crow];

  CONCERT -> ZONE            [dir=both, arrowtail=tee, arrowhead=crow];
  CONCERT -> ORDER           [dir=both, arrowtail=tee, arrowhead=crow];
  CONCERT -> QUEUE_TOKEN     [dir=both, arrowtail=tee, arrowhead=crow];
  ZONE -> SEAT               [dir=both, arrowtail=tee, arrowhead=crow];

  ORDER -> ORDER_ITEM        [dir=both, arrowtail=tee, arrowhead=crow];
  ORDER -> PAYMENT           [dir=both, arrowtail=tee, arrowhead=teeodot];
  ORDER -> TICKET            [dir=both, arrowtail=tee, arrowhead=crow];

  SEAT -> ORDER_ITEM         [dir=both, arrowtail=tee, arrowhead=teeodot, style=dashed];
  SEAT -> TICKET             [dir=both, arrowtail=tee, arrowhead=teeodot, style=dashed];
}
